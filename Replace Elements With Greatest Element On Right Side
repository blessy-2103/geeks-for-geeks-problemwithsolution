class Solution {
    public int[] replaceElements(int[] arr) {
        int n = arr.length;
        int last = -1;
        for(int i = n-1;i>=0;i--){
           int a = arr[i];
           arr[i] = last;
           if(a > last){
            last = a;
           }
        }
        return arr;
    }
}
